<!DOCTYPE html>

<html lang="uk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Броня та Шоломи | ABI Ukraine</title>
<meta name="description" content="Повний тір-ліст броні та шоломів Arena Breakout Infinite українською. Всі тіри 1-6, характеристики, ціни 2025.">
<meta name="robots" content="index, follow">
<link rel="icon" type="image/png" href="logo.png.PNG">
<style>
:root{
  --bg:#0a0c10;--surface:#111520;--card:#161b26;--border:#1e2535;
  --orange:#ff9f1c;--gold:#ffb84d;
  --t1:#888;--t2:#4db8ff;--t3:#23a55a;--t4:#ff9f1c;--t5:#ff6b35;--t6:#ff4d4d;
  --text:#e8eaf0;--muted:#7a8099;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:Arial,sans-serif;background:var(--bg);color:var(--text);min-height:100vh}

/* HEADER */
header{position:fixed;top:0;width:100%;background:rgba(10,12,16,.92);backdrop-filter:blur(10px);border-bottom:1px solid var(–border);z-index:1000}
.nav{max-width:1200px;margin:auto;display:flex;justify-content:space-between;align-items:center;padding:14px 20px}
.logo-link{display:flex;align-items:center;gap:10px;text-decoration:none}
.logo-link img{height:48px;width:auto}
.nav-links{display:flex;gap:10px}
.back-btn,.nav-btn{display:inline-flex;align-items:center;gap:7px;color:var(–muted);text-decoration:none;font-size:13px;font-weight:500;padding:8px 14px;border-radius:8px;border:1px solid var(–border);transition:.2s}
.back-btn:hover,.nav-btn:hover{color:var(–orange);border-color:var(–orange)}
.nav-btn svg,.back-btn svg{width:14px;height:14px;fill:currentColor}

/* HERO */
.page-hero{padding:110px 20px 40px;text-align:center;background:linear-gradient(180deg,rgba(255,77,77,.04) 0%,transparent 100%);border-bottom:1px solid var(–border);max-width:1200px;margin:0 auto}
.page-hero h1{font-size:48px;font-weight:900;letter-spacing:2px;color:#fff}
.page-hero h1 span{color:var(–orange)}
.page-hero p{color:var(–muted);font-size:15px;margin-top:10px;max-width:520px;margin-inline:auto;line-height:1.6}
.page-badge{display:inline-block;margin-top:16px;background:var(–surface);border:1px solid var(–border);border-radius:20px;padding:5px 16px;font-size:12px;color:var(–gold)}

/* TIER LEGEND */
.tier-legend{display:flex;justify-content:center;gap:10px;flex-wrap:wrap;padding:20px;max-width:1200px;margin:0 auto;border-bottom:1px solid var(–border)}
.tl{display:inline-flex;align-items:center;gap:6px;padding:5px 12px;border-radius:6px;font-size:12px;font-weight:700;letter-spacing:1px}
.tl-1{background:rgba(136,136,136,.1);color:var(–t1);border:1px solid rgba(136,136,136,.2)}
.tl-2{background:rgba(77,184,255,.1);color:var(–t2);border:1px solid rgba(77,184,255,.2)}
.tl-3{background:rgba(35,165,90,.1);color:var(–t3);border:1px solid rgba(35,165,90,.2)}
.tl-4{background:rgba(255,159,28,.1);color:var(–t4);border:1px solid rgba(255,159,28,.2)}
.tl-5{background:rgba(255,107,53,.1);color:var(–t5);border:1px solid rgba(255,107,53,.2)}
.tl-6{background:rgba(255,77,77,.15);color:var(–t6);border:1px solid rgba(255,77,77,.3)}

/* TABS */
.tabs-wrap{position:sticky;top:76px;z-index:900;background:rgba(10,12,16,.95);backdrop-filter:blur(8px);border-bottom:1px solid var(–border)}
.tabs{max-width:1200px;margin:0 auto;display:flex;overflow-x:auto;scrollbar-width:none;padding:0 20px}
.tabs::-webkit-scrollbar{display:none}
.tab{flex-shrink:0;padding:16px 24px;cursor:pointer;font-size:14px;font-weight:700;letter-spacing:1px;color:var(–muted);border-bottom:2px solid transparent;transition:.2s;white-space:nowrap;display:flex;align-items:center;gap:8px;background:none;border-top:none;border-left:none;border-right:none;text-transform:uppercase}
.tab:hover{color:var(–text)}
.tab.active{color:var(–orange);border-bottom-color:var(–orange)}
.tab svg{width:16px;height:16px;fill:currentColor}

/* CONTENT */
.content{max-width:1200px;margin:0 auto;padding:40px 20px 80px}
.category{display:none}
.category.active{display:block}
.cat-header{margin-bottom:30px;padding-bottom:20px;border-bottom:1px solid var(–border)}
.cat-header h2{font-size:30px;font-weight:900;color:#fff;display:flex;align-items:center;gap:10px}
.cat-header h2 svg{width:26px;height:26px;fill:var(–orange)}
.cat-header p{color:var(–muted);margin-top:8px;font-size:14px;line-height:1.6;max-width:700px}

/* TIER SECTION */
.tier-section{margin-bottom:40px}
.tier-label{
display:inline-flex;align-items:center;gap:8px;
padding:6px 16px;border-radius:8px;
font-size:13px;font-weight:700;letter-spacing:2px;
margin-bottom:16px;text-transform:uppercase;
}
.tier-1-label{background:rgba(136,136,136,.12);color:var(–t1);border:1px solid rgba(136,136,136,.25)}
.tier-2-label{background:rgba(77,184,255,.1);color:var(–t2);border:1px solid rgba(77,184,255,.25)}
.tier-3-label{background:rgba(35,165,90,.1);color:var(–t3);border:1px solid rgba(35,165,90,.25)}
.tier-4-label{background:rgba(255,159,28,.1);color:var(–t4);border:1px solid rgba(255,159,28,.25)}
.tier-5-label{background:rgba(255,107,53,.1);color:var(–t5);border:1px solid rgba(255,107,53,.25)}
.tier-6-label{background:rgba(255,77,77,.12);color:var(–t6);border:1px solid rgba(255,77,77,.3)}

/* GRID */
.gear-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px}

/* GEAR CARD */
.gear-card{background:var(–card);border:1px solid var(–border);border-radius:14px;overflow:hidden;transition:.25s;position:relative}
.gear-card:hover{transform:translateY(-3px);box-shadow:0 8px 28px rgba(0,0,0,.4)}
.gear-card::before{content:’’;position:absolute;left:0;top:0;bottom:0;width:3px;border-radius:3px 0 0 3px}
.gear-card.t1::before{background:var(–t1)}
.gear-card.t2::before{background:var(–t2)}
.gear-card.t3::before{background:var(–t3)}
.gear-card.t4::before{background:var(–t4)}
.gear-card.t5::before{background:var(–t5)}
.gear-card.t6::before{background:var(–t6)}

.gear-visual{height:110px;background:linear-gradient(135deg,#0d1018,#161b26);display:flex;align-items:center;justify-content:center;border-bottom:1px solid var(–border);position:relative;overflow:hidden}
.gear-visual::after{content:’’;position:absolute;inset:0;background:radial-gradient(ellipse at 50% 120%,rgba(255,159,28,.06),transparent 70%)}
.gear-visual svg{position:relative;z-index:1;filter:drop-shadow(0 2px 10px rgba(255,159,28,.25))}

.gear-info{padding:14px 14px 14px 18px}
.gear-top{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:5px}
.gear-name{font-size:17px;font-weight:700;color:#fff;line-height:1.1}
.gear-tier-badge{font-size:11px;font-weight:700;padding:3px 8px;border-radius:5px;letter-spacing:1px;flex-shrink:0}
.t1 .gear-tier-badge{background:rgba(136,136,136,.15);color:var(–t1)}
.t2 .gear-tier-badge{background:rgba(77,184,255,.15);color:var(–t2)}
.t3 .gear-tier-badge{background:rgba(35,165,90,.15);color:var(–t3)}
.t4 .gear-tier-badge{background:rgba(255,159,28,.15);color:var(–t4)}
.t5 .gear-tier-badge{background:rgba(255,107,53,.15);color:var(–t5)}
.t6 .gear-tier-badge{background:rgba(255,77,77,.15);color:var(–t6)}

.gear-material{font-size:11px;color:var(–muted);margin-bottom:8px;display:flex;align-items:center;gap:4px}
.gear-desc{font-size:12px;color:#9aa0b5;line-height:1.55;margin-bottom:12px}

.stats{display:flex;flex-direction:column;gap:6px}
.stat-row{display:flex;align-items:center;gap:8px}
.stat-label{font-size:10px;color:var(–muted);width:80px;flex-shrink:0;font-weight:500}
.stat-bar{flex:1;height:4px;background:var(–border);border-radius:2px;overflow:hidden}
.stat-fill{height:100%;border-radius:2px;background:linear-gradient(90deg,var(–orange),#ffcc80)}
.stat-val{font-size:10px;color:var(–muted);width:22px;text-align:right;flex-shrink:0}

.gear-tags{display:flex;flex-wrap:wrap;gap:5px;margin-top:10px}
.tag{font-size:10px;padding:3px 8px;border-radius:5px;background:#1a2030;color:#888;border:1px solid #232b3a}
.tag.good{color:#23a55a;background:rgba(35,165,90,.08);border-color:rgba(35,165,90,.2)}
.tag.bad{color:#ff6b6b;background:rgba(255,107,107,.08);border-color:rgba(255,107,107,.2)}

.gear-price{display:inline-flex;align-items:center;gap:4px;margin-top:10px;font-size:11px;font-weight:600;color:var(–gold);background:rgba(255,184,77,.08);padding:3px 10px;border-radius:5px}

/* FOOTER */
footer{background:var(–surface);border-top:1px solid var(–border);padding:28px 20px;text-align:center;color:var(–muted);font-size:13px}
footer a{color:var(–orange);text-decoration:none}

@media(max-width:600px){
.page-hero h1{font-size:32px}
.gear-grid{grid-template-columns:1fr}
.tab{padding:13px 14px;font-size:12px}
.nav-links .nav-btn span{display:none}
}
</style>

</head>
<body>

<header>
<div class="nav">
  <a href="index.html" class="logo-link">
    <img src="logo.png.PNG" alt="ABI Ukraine" width="48" height="48">
  </a>
  <div class="nav-links">
    <a href="weapons.html" class="nav-btn">
      <svg viewBox="0 0 24 24"><path d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm4 4h14v-2H7v2zm0-8h14v-2H7v2zm0-4v2h14V9H7zM3 9h2V7H3v2z"/></svg>
      <span>Зброя</span>
    </a>
    <a href="index.html" class="back-btn">
      <svg viewBox="0 0 24 24"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
      <span>Головна</span>
